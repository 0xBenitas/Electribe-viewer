# Copy to infra/.env and fill in. Used by docker-compose.

# Public domain Caddy provisions TLS for (A record → your VPS).
DOMAIN=jam.example.org

# Baked into the cockpit build (Vite). The WS relay sits behind Caddy at /ws.
VITE_SESSION_URL=wss://jam.example.org/ws

# Where players point their native NINJAM client (host:port). Direct TCP, not Caddy.
VITE_NINJAM_HOST=jam.example.org:2049
